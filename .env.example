# Required for classification and synthesis. OpenAI web search uses this too.
OPENAI_API_KEY=sk-placeholder

# Required for email delivery.
SENDGRID_API_KEY=SG.placeholder
DIGEST_TO=recipient@example.com
DIGEST_FROM=verified-sender@example.com

# Required only for Google Docs output.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"endometriosis-dx-digest@example-project.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\nPLACEHOLDER\\n-----END PRIVATE KEY-----\\n","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_DOC_ID=google-doc-id-placeholder

# Optional source/search keys.
NCBI_API_KEY=optional-ncbi-key
GOOGLE_API_KEY=optional-google-api-key
GOOGLE_CSE_ID=optional-google-cse-id
SERPAPI_API_KEY=optional-serpapi-key
TAVILY_API_KEY=optional-tavily-key
BRAVE_SEARCH_API_KEY=optional-brave-key
